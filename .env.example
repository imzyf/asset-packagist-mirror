# Public base URL where this mirror is served (the web root is ./public).
# Used verbatim to build packages.json "providers-url" -- MUST end with a
# trailing slash. Copy this file to .env and adjust.
#
# - GitHub Pages (default): root-relative repo path, e.g. "/asset-packagist-mirror/".
#   Stays portable across forks and custom domains -- only the path matters.
# - Self-hosted nginx with web root at "/": leave it as "/".
# - Custom domain / other absolute URL: RAW_BASE=https://composer.example.com/

RAW_BASE=/asset-packagist-mirror/
