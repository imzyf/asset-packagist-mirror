# Public base URL where this mirror is served (the web root is ./public).
# It is used verbatim to build packages.json "providers-url", so it MUST end
# with a trailing slash. Copy this file to .env and adjust.
#
# Default (unset): "/" -> root-relative "/p/..." (works on any host serving
# the web root at "/"). This is the recommended setup for self-hosted nginx.
#
# Absolute GitHub raw URL (note the trailing slash):
#   RAW_BASE=https://raw.githubusercontent.com/imzyf/asset-packagist-mirror/main/public/

RAW_BASE=https://raw.githubusercontent.com/imzyf/asset-packagist-mirror/main/public/
